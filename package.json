{
  "name": "teste-tecnico-v5",
  "version": "5.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest watch",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev": "turbo dev"
  },
  "devDependencies": {
    "@shopify/flash-list": "^1.7.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "react-native": "^0.76.0",
    "react-native-reanimated": "^3.16.0",
    "react-test-renderer": "^19.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "overrides": {
    "react-native": {
      "react": "$react",
      "@types/react": "$@types/react"
    },
    "react-native-reanimated": {
      "react": "$react",
      "react-native": "$react-native"
    },
    "@shopify/flash-list": {
      "react": "$react",
      "react-native": "$react-native",
      "@types/react": "$@types/react"
    },
    "@testing-library/react-native": {
      "react": "$react",
      "react-native": "$react-native"
    },
    "react-test-renderer": {
      "react": "$react"
    }
  },
  "packageManager": "npm@10.8.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
